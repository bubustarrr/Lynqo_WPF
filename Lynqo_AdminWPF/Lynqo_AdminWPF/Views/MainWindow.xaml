<Window x:Class="Lynqo_AdminWPF.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Lynqo Admin"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.Background>
            <StaticResource ResourceKey="LynqoGradient" />
        </Grid.Background>

        <Grid Margin="40">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Fejléc a weboldalhoz hasonlóan -->
            <DockPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Lynqo"
                           FontSize="26"
                           FontWeight="Bold"
                           Foreground="White"
                           DockPanel.Dock="Left"/>
                <TextBlock Text="Admin Panel"
                           FontSize="18"
                           Foreground="White"
                           Margin="10,4,0,0"/>
            </DockPanel>

            <Border Grid.Row="1" Style="{StaticResource CardBorder}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Oldalsáv -->
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Navigáció"
                                   FontWeight="Bold"
                                   Margin="5,0,0,10"/>
                        <Button Content="Felhasználók"
                                Style="{StaticResource PrimaryButton}"
                                Command="{Binding ShowUsersCommand}"/>
                    </StackPanel>

                    <!-- Fő tartalom -->
                    <Frame Grid.Column="1"
                           Margin="20,0,0,0"
                           Content="{Binding CurrentPage}"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
