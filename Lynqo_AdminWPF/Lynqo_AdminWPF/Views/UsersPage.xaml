<Page x:Class="Lynqo_AdminWPF.Views.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Felhasználók"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,10"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0"
                      ItemsSource="{Binding Users}"
                      SelectedItem="{Binding SelectedUser}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      Margin="0,0,10,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Felhasználónév" Binding="{Binding Username}" Width="*"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="2*"/>
                    <DataGridTextColumn Header="Szerep" Binding="{Binding Role}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Kitiltva" Binding="{Binding IsBanned}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Kiválasztott felhasználó" FontWeight="Bold" Margin="0,0,0,10"/>
                <TextBlock Text="{Binding SelectedUser.Username}" FontSize="16" Margin="0,0,0,10"/>

                <Button Content="Admin-ná léptetés"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding PromoteCommand}"
                        IsEnabled="{Binding CanPromote}"/>
                <Button Content="Felhasználóvá visszaállítás"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding DemoteCommand}"
                        IsEnabled="{Binding CanDemote}"/>

                <Separator Margin="0,10,0,10"/>

                <Button Content="Profilkép csere"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ChangePictureCommand}"
                        IsEnabled="{Binding HasSelection}"/>

                <Separator Margin="0,10,0,10"/>

                <TextBlock Text="Kitiltás oka:"/>
                <TextBox Text="{Binding BanReason}" Height="60" TextWrapping="Wrap"/>
                <TextBlock Text="Kitiltás vége (opcionális):" Margin="0,5,0,0"/>
                <DatePicker SelectedDate="{Binding BanUntil}"/>

                <Button Content="Kitiltás"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding BanCommand}"
                        IsEnabled="{Binding CanBan}"/>

                <Button Content="Feloldás"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding UnbanCommand}"
                        IsEnabled="{Binding CanUnban}"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
