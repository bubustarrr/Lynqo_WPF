<Page x:Class="Lynqo_AdminWPF.Views.UsersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="UsersPage">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Felhasználók kezelése" FontSize="24" FontWeight="Bold" Margin="0,0,0,15" Foreground="#333"/>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" ItemsSource="{Binding Users}" SelectedItem="{Binding SelectedUser}" 
                      AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column"
                      Background="White" BorderBrush="#E0E0E0" BorderThickness="1" RowHeight="30">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Felhasználónév" Binding="{Binding Username}" Width="*"/>
                    <DataGridTextColumn Header="Email cím" Binding="{Binding Email}" Width="*"/>
                    <DataGridTextColumn Header="Rang" Binding="{Binding Role}" Width="80"/>
                    <DataGridCheckBoxColumn Header="Prémium" Binding="{Binding IsPremium}" Width="65"/>
                    <DataGridCheckBoxColumn Header="Kitiltva" Binding="{Binding IsBanned}" Width="70"/>
                </DataGrid.Columns>
            </DataGrid>

            <ScrollViewer Grid.Column="1" Margin="15,0,0,0" VerticalScrollBarVisibility="Auto">

                <StackPanel IsEnabled="{Binding HasSelection}">

                    <TextBlock Text="Kiválasztott felhasználó műveletei" FontWeight="Bold" FontSize="14" Margin="0,0,0,10" Foreground="#555"/>

                    <GroupBox Header="Szerepkör (Rang)" Margin="0,0,0,15" Padding="10">
                        <StackPanel>
                            <Button Content="⭐ Kinevezés Adminná" 
                                    Command="{Binding PromoteCommand}" 
                                    Margin="0,5" Padding="5" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>

                            <Button Content="⬇️ Admin jog elvétele" 
                                    Command="{Binding DemoteCommand}" 
                                    Margin="0,5" Padding="5" Background="#FF9800" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Előfizetés (Prémium)" Margin="0,0,0,15" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Csomag időtartama:" Margin="0,0,0,5" Foreground="#555"/>
                            <ComboBox SelectedIndex="{Binding SelectedSubscriptionIndex}" Margin="0,0,0,10" Padding="5">
                                <ComboBoxItem Content="1 Hónap"/>
                                <ComboBoxItem Content="1 Év"/>
                            </ComboBox>

                            <CheckBox Content="Automatikus megújítás (Auto-renew)" 
                                      IsChecked="{Binding IsAutoRenew}" 
                                      Margin="0,0,0,10" 
                                      Foreground="#333"/>

                            <Button Content="💎 Prémium Adása" 
                                    Command="{Binding GrantSubscriptionCommand}" 
                                    Margin="0,5" Padding="5" Background="#9C27B0" Foreground="White" FontWeight="Bold"/>

                            <Button Content="❌ Prémium Elvétele" 
                                    Command="{Binding RevokeSubscriptionCommand}" 
                                    Margin="0,5" Padding="5" Background="#E91E63" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Kitiltás (Ban) beállítások" Margin="0,0,0,15" Padding="10">
                        <StackPanel>
                            <TextBlock Text="Kitiltás oka (opcionális):" Margin="0,0,0,5" Foreground="#555"/>
                            <TextBox Text="{Binding BanReason, UpdateSourceTrigger=PropertyChanged}" 
                                     Margin="0,0,0,10" Padding="5" ToolTip="Írd ide miért tiltod ki..."/>

                            <TextBlock Text="Kitiltás lejárata (opcionális):" Margin="0,0,0,5" Foreground="#555"/>
                            <DatePicker SelectedDate="{Binding BanUntil, UpdateSourceTrigger=PropertyChanged}" 
                                        Margin="0,0,0,15"/>

                            <Button Content="🔨 Felhasználó kitiltása" 
                                    Command="{Binding BanCommand}" 
                                    Margin="0,5" Padding="5" Background="#F44336" Foreground="White" FontWeight="Bold"/>

                            <Button Content="✅ Kitiltás feloldása" 
                                    Command="{Binding UnbanCommand}" 
                                    Margin="0,5" Padding="5" Background="#2196F3" Foreground="White" FontWeight="Bold"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Egyéb" Padding="10">
                        <Button Content="🖼️ Profilkép módosítása" 
                                Command="{Binding ChangePictureCommand}" 
                                Padding="5"/>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>